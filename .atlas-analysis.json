  "keyFeatures": [
    "Autonomous AI agents with real-world capabilities",
    "LLM provider agnostic (OpenAI, Anthropic, Google, Mistral, xAI, DeepSeek, Ollama, OpenRouter)",
    "Model Context Protocol (MCP) integration",
    "20+ built-in skills (.agents convention)",
    "Workflow automation with cron scheduling",
    "Built-in tools: Git, filesystem, shell, web search, HTTP, email",
    "Auto-approve policies for workflow autonomy",
    "CI/CD integration with raw output and auto-approve",
    "Effect-TS architecture for reliability",
    "Interactive CLI with in-chat slash commands"
  ],
  "publicApiSurface": [
    "jazz - Start interactive agent",
    "jazz agent create - Create new agent",
    "jazz agent chat <name> - Chat with specific agent",
    "jazz agent list - List all agents",
    "jazz agent delete <name> - Delete an agent",
    "jazz workflow list - List workflows",
    "jazz workflow run <name> - Run workflow",
    "jazz workflow schedule <name> - Schedule workflow",
    "jazz workflow unschedule <name> - Unschedule workflow",
    "jazz mcp add - Add MCP server",
    "jazz mcp list - List MCP servers",
    "jazz mcp remove <name> - Remove MCP server",
    "jazz config show - View configuration",
    "jazz config wizard - Run configuration wizard",
    "jazz auth gmail login - Authenticate Gmail",
    "jazz auth gmail logout - Logout Gmail",
    "jazz update - Update to latest version",
    "/tools - View available tools",
    "/skills - Browse agent skills",
    "/model - Change LLM model",
    "/mode - Change agent mode",
    "/cost - View token costs",
    "/context - View context window",
    "/compact - Enable compact mode",
    "/switch - Switch agent",
    "/workflows - View workflows",
    "/help - Show help"
  ]
